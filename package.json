{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc",
    "dev": "npm-run-all clean build start-dev-server",
    "start-dev-server": "tsc-watch --onSuccess \"node --inspect=0.0.0.0:9229 dist/server.js 9000\"",
    "clean-database": "node dist/data/clear.db.js",
    "populate-database": "node dist/data/clear.db.js && node dist/data/db.populate.js",
    "start-server": "node dist/server.js"
  },
  "author": "Grigor Stoyanov",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "http-errors": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.17.2",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.2",
    "tsc-watch": "^7.2.0"
  }
}
