{
    "compilerOptions": {
        "target": "es5",
        "module": "commonjs",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "removeComments": true,
        "outDir": "dist",
        "rootDir": "src",
        "noEmitOnError": true,
        "allowJs":true,
        "checkJs": true,
        "esModuleInterop": true,
        "sourceMap": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "inlineSources": true
    }
}